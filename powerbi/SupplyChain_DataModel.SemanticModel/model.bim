        "expression": [
          "let",
          "    Fonte = Csv.Document(File.Contents(\"C:\\gogogo\\gogogo\\data\\DataCoSupplyChainDataset.csv\"),[Delimiter=\",\", Columns=53, Encoding=1252, QuoteStyle=QuoteStyle.None]),",
          "    #\"Cabeçalhos Promovidos\" = Table.PromoteHeaders(Fonte, [PromoteAllScalars=true]),",
          "    #\"Tipo Alterado\" = Table.TransformColumnTypes(#\"Cabeçalhos Promovidos\",{{\"Type\", type text}, {\"Days for shipping (real)\", Int64.Type}, {\"Days for shipment (scheduled)\", Int64.Type}, {\"Benefit per order\", Int64.Type}, {\"Sales per customer\", Int64.Type}, {\"Delivery Status\", type text}, {\"Late_delivery_risk\", Int64.Type}, {\"Category Id\", Int64.Type}, {\"Category Name\", type text}, {\"Customer City\", type text}, {\"Customer Country\", type text}, {\"Customer Email\", type text}, {\"Customer Fname\", type text}, {\"Customer Id\", Int64.Type}, {\"Customer Lname\", type text}, {\"Customer Password\", type text}, {\"Customer Segment\", type text}, {\"Customer State\", type text}, {\"Customer Street\", type text}, {\"Customer Zipcode\", Int64.Type}, {\"Department Id\", Int64.Type}, {\"Department Name\", type text}, {\"Latitude\", Int64.Type}, {\"Longitude\", Int64.Type}, {\"Market\", type text}, {\"Order City\", type text}, {\"Order Country\", type text}, {\"Order Customer Id\", Int64.Type}, {\"order date (DateOrders)\", type text}, {\"Order Id\", Int64.Type}, {\"Order Item Cardprod Id\", Int64.Type}, {\"Order Item Discount\", Int64.Type}, {\"Order Item Discount Rate\", Int64.Type}, {\"Order Item Id\", Int64.Type}, {\"Order Item Product Price\", Int64.Type}, {\"Order Item Profit Ratio\", Int64.Type}, {\"Order Item Quantity\", Int64.Type}, {\"Sales\", Int64.Type}, {\"Order Item Total\", Int64.Type}, {\"Order Profit Per Order\", Int64.Type}, {\"Order Region\", type text}, {\"Order State\", type text}, {\"Order Status\", type text}, {\"Order Zipcode\", Int64.Type}, {\"Product Card Id\", Int64.Type}, {\"Product Category Id\", Int64.Type}, {\"Product Description\", type text}, {\"Product Image\", type text}, {\"Product Name\", type text}, {\"Product Price\", Int64.Type}, {\"Product Status\", Int64.Type}, {\"shipping date (DateOrders)\", type text}, {\"Shipping Mode\", type text}})",
          "in",
          "    #\"Tipo Alterado\""
        ],
        "kind": "m",
        "lineageTag": "027e978d-9997-42d3-9278-a137c90b68d0"
      }
    ],
